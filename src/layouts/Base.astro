---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
    title: string;
    description: string;
    ogType?: 'website' | 'article';
    ogImage?: string;
    publishedTime?: Date;
    modifiedTime?: Date;
}
const props = Astro.props;
---
<!doctype html>
<html lang="en-GB">
    <head>
        <BaseHead {...props} />
    </head>
    <body>
        <Header />
        <main><slot /></main>
        <Footer />
    </body>
</html>
